TabFarm:AddToggle({
    Name = "Auto Magnet / Pull Loot",
    Description = "Teleporta os itens direto pra posição",
    Default = false,

    Callback = function(state)
        getgenv().AutoMagnet = state

        if state then
            task.spawn(function()

                local Players = game:GetService("Players")
                local RunService = game:GetService("RunService")

                local player = Players.LocalPlayer
                local character = player.Character or player.CharacterAdded:Wait()
                local rootPart = character:WaitForChild("HumanoidRootPart")

                -- POSIÇÃO DOS ITENS
                local ITEM_POSITION = Vector3.new(
       -32.00947952270508, 11.65832233428955, -51.51183319091797
                )

                local connection
                connection = RunService.Heartbeat:Connect(function()

                    if not getgenv().AutoMagnet then
                        connection:Disconnect()
                        return
                    end

                    character = player.Character
                    if not character then return end

                    rootPart = character:FindFirstChild("HumanoidRootPart")
                    if not rootPart then return end

                    local lootFolder =
                        workspace:FindFirstChild("LootDrops")
                        or workspace:FindFirstChild("Drops")

                    if not lootFolder then return end

                    for _, item in ipairs(lootFolder:GetChildren()) do
                        pcall(function()

                            local core

                            -- Procura a peça principal do item
                            if item:FindFirstChild("VisualModel")
                                and item.VisualModel:FindFirstChild("Core") then

                                core = item.VisualModel.Core

                            elseif item:FindFirstChild("Core") then
                                core = item.Core

                            else
                                core = item:FindFirstChildWhichIsA("BasePart")
                            end

                            if core and core:IsA("BasePart") then

                                -- TELEPORTA ITEM PRA POSIÇÃO
                                core.CFrame = CFrame.new(ITEM_POSITION)

                                -- Opcional: leva pro player depois
                                -- core.CFrame = rootPart.CFrame
                            end
                        end)
                    end
                end)
            end)
        end
    end
})
